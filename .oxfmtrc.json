{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "quoteProps": "consistent",
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "useTabs": false,
  "printWidth": 80,
  "sortPackageJson": false,
  "ignorePatterns": [
    "yarn.lock",
    ".yarn/",
    "lib/",
    "coverage/",
    "node_modules/",
    "example/dist/",
    "docs/.next/",
    "docs/.source/",
    "docs/out/",
    "docs/content/"
  ]
}
