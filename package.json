{
  "name": "react-native-preview-url-monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "lint": "oxlint",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm --filter react-native-preview-url prepare",
    "example": "pnpm --filter react-native-preview-url-example"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.6.0",
    "@evilmartians/lefthook": "^1.5.0",
    "commitlint": "^19.6.1",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "^5.8.3"
  },
  "workspaces": [
    "packages/*",
    "example"
  ],
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
